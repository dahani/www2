# -----------------------------------------------------------------------------
# StockPro — Frontend default environment variables (committed defaults)
# -----------------------------------------------------------------------------
# For local overrides create a `.env.local` file (git-ignored by default in Vite).
# See `.env.example` for full documentation.
# -----------------------------------------------------------------------------

# Base URL of the Symfony 7 API backend.
# Empty by default → the app runs in local (localStorage) mode.
# Uncomment / edit the line below to enable the API backend:
#
VITE_API_URL=https://127.0.0.1:8000/api

