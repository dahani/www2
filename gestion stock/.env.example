# -----------------------------------------------------------------------------
# StockPro — Frontend environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and adjust the values as needed.
# Any variable prefixed with VITE_ will be exposed to the client-side code.
#
# Docs: https://vite.dev/guide/env-and-mode
# -----------------------------------------------------------------------------

# Base URL of the Symfony 7 API backend (see backend/README.md).
# Leave empty to run the app in local-only mode (data stored in localStorage).
#
# Examples:
#   VITE_API_URL=http://127.0.0.1:8000/api          # symfony serve (dev)
#   VITE_API_URL=http://localhost:8000/api          # php -S 127.0.0.1:8000 -t public
#   VITE_API_URL=https://api.stockpro.example.com   # production
VITE_API_URL=
